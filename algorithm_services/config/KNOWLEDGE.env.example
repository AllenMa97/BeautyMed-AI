# ========== 知识库配置 ==========

# 知识库服务地址
KNOWLEDGE_BASE_SERVICE_URL=http://localhost:8002

# 默认检索模式 (vector/keyword/hybrid)
# - vector: 向量检索（语义相似度）
# - keyword: 关键词检索（精确匹配）
# - hybrid: 混合检索（结合向量和关键词，推荐）
KNOWLEDGE_DEFAULT_SEARCH_MODE=hybrid

# 默认检索数量
# 建议范围：5-20
KNOWLEDGE_DEFAULT_TOP_K=10

# 默认相似度阈值
# 建议范围：0.1-0.5，值越小返回结果越多
KNOWLEDGE_DEFAULT_THRESHOLD=0.3

# 默认检索类型 (all/products/entries)
# - all: 检索产品和知识条目
# - products: 只检索产品
# - entries: 只检索知识条目
KNOWLEDGE_DEFAULT_SEARCH_TYPE=all
