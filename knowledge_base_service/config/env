# -----------------------------------------------------------------------------
# Chunking 分块配置
# -----------------------------------------------------------------------------

# 语义相似度阈值（0-1 之间）
# 
# 【作用】:
#     用于识别文档中的话题转换点。系统会计算相邻句子的语义相似度，
#     当相似度低于此阈值时，认为发生了话题转换，在此处切断形成 chunk 边界。
# 
# 【影响】:
#     - 调低（如 0.5）: 
#       * chunk 更大，包含更多内容
#       * 可能将多个子话题合并到一个 chunk 中
#       * 适合内容连贯、话题转换少的文档
#       * 检索时上下文更完整，但可能包含无关信息
#     
#     - 调高（如 0.7）:
#       * chunk 更小，语义更聚焦
#       * 能更精确地识别话题转换
#       * 适合话题跳跃、内容分散的文档
#       * 检索时精度更高，但可能丢失上下文
# 
# 【示例】:
#     假设有以下文档内容:
#     
#     "玻尿酸是一种天然多糖。它具有强保水能力。广泛用于医美填充。
#      兰蔻小黑瓶售价 1200 元。使用方法：每日早晚各一次。"
#     
#     句子 1-3 的相似度 = 0.85（都在讲玻尿酸的定义和用途）
#     句子 3-4 的相似度 = 0.45（从"玻尿酸定义"跳到"兰蔻价格"，话题转换）
#     
#     如果 CHUNK_SIMILARITY_THRESHOLD = 0.6:
#     - 句子 1-3 合并为一个 chunk（相似度 0.85 > 0.6）
#     - 在句子 3-4 之间切断（相似度 0.45 < 0.6）
#     - 句子 4-5 合并为另一个 chunk
#     
#     如果 CHUNK_SIMILARITY_THRESHOLD = 0.5:
#     - 句子 1-5 可能都合并为一个 chunk（阈值更低，更不容易切断）
#     
#     如果 CHUNK_SIMILARITY_THRESHOLD = 0.7:
#     - 可能在句子 2-3 之间就切断了（阈值更高，更容易切断）
#     - 形成更小的 chunk
# 
# 【推荐值】:
#     - 默认：0.6（适用于大多数医美文档）
#     - 产品文档为主：0.5-0.6（产品描述通常连贯）
#     - 学术文献为主：0.6-0.7（学术论文话题转换频繁）
#     - 混合文档：0.6（默认值）
# 
# 【调整建议】:
#     1. 先使用默认值 0.6
#     2. 观察检索结果：
#        - 如果发现一个 chunk 包含多个不相关话题 → 调低到 0.5
#        - 如果发现相关上下文被切断 → 调高到 0.7
#     3. 根据实际效果微调，每次调整 0.05-0.1
CHUNK_SIMILARITY_THRESHOLD=0.6

# 父 chunk 最大 token 数
# 
# 【作用】: 控制每个父 chunk 的大小
# 【影响】: 
#     - 调大：上下文更完整，但可能包含冗余信息
#     - 调小：语义更聚焦，但可能丢失上下文
# 【推荐值】: 512（默认），适合大多数场景
CHUNK_PARENT_MAX_TOKENS=512

# 子 chunk 最大 token 数
# 
# 【作用】: 控制每个子 chunk 的大小（用于检索）
# 【影响】:
#     - 调大：检索时匹配的信息更多，但精度可能下降
#     - 调小：检索精度更高，但可能遗漏相关信息
# 【推荐值】: 128（默认），适合细粒度检索
CHUNK_CHILD_MAX_TOKENS=128

# 最小 token 数
# 
# 【作用】: 避免生成过短的 chunk
# 【影响】: 过短的 chunk 会合并到前一个 chunk 中
# 【推荐值】: 50（默认）
CHUNK_MIN_TOKENS=50

# 是否启用父子分块
# 
# 【作用】: 是否生成父子 chunk 结构
# 【影响】:
#     - True: 生成父子 chunk，检索时用子 chunk，返回时带父 chunk（推荐）
#     - False: 只生成父 chunk，没有父子关系
# 【推荐值】: True（默认，强烈推荐启用）
CHUNK_ENABLE_PARENT_CHILD=True

# -----------------------------------------------------------------------------
# Embedding 嵌入模型配置
# -----------------------------------------------------------------------------

# Embedding 模型名称
# 【重要】整个知识库必须使用同一个 Embedding 模型，确保向量在同一个 semantic space
# 【可选值】:
#     - text-embedding-v3: 最新版（推荐，支持自定义维度）
#     - text-embedding-v2: 旧版（固定 1536 维）
#     - text-embedding-v1: 最旧版
EMBEDDING_MODEL=text-embedding-v3

# Embedding 向量维度
# 【重要】必须与模型匹配，修改模型后需同步修改此值
# 【可选值】:
#     - text-embedding-v3: 支持 512/768/1024/1536（推荐 1024）
#     - text-embedding-v2: 固定 1536
EMBEDDING_DIMENSION=1024

# Embedding API Base URL（可选，默认使用阿里云官方地址）
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# Embedding 批量请求大小（阿里云限制最大为 10）
EMBEDDING_BATCH_SIZE=10

# -----------------------------------------------------------------------------
# 向量检索配置
# -----------------------------------------------------------------------------

# HNSW 索引参数 M
# 
# 【作用】: 控制 HNSW 图的连接密度
# 【影响】:
#     - 调大：检索精度更高，但索引更大、构建更慢
#     - 调小：索引更小、构建更快，但精度可能下降
# 【推荐值】: 16（默认）
HNSW_M=16

# HNSW 构建时的 ef 参数
# 
# 【作用】: 控制构建索引时的搜索范围
# 【影响】:
#     - 调大：索引质量更高，但构建更慢
#     - 调小：构建更快，但质量可能下降
# 【推荐值】: 200（默认）
HNSW_EF_CONSTRUCTION=200

# HNSW 检索时的 ef 参数
# 
# 【作用】: 控制检索时的搜索范围
# 【影响】:
#     - 调大：检索精度更高，但速度更慢
#     - 调小：检索更快，但精度可能下降
# 【推荐值】: 50（默认）
HNSW_EF_SEARCH=50

# -----------------------------------------------------------------------------
# Rerank 重排序配置
# -----------------------------------------------------------------------------

# 是否启用 LLM Reranker
# 
# 【作用】: 是否使用在线 LLM 对检索结果进行重排序
# 【影响】:
#     - True: 检索精度更高，但需要调用 LLM API（有成本）
#     - False: 只用向量检索分数，速度快但精度可能下降
# 【推荐值】: True（默认，推荐启用）
ENABLE_LLM_RERANKER=True

# LLM Reranker 的模型名称
# 
# 【可选值】:
#     - qwen-plus: 通义千问 Plus（推荐，平衡性能和成本）
#     - qwen-max: 通义千问 Max（精度最高，成本也最高）
#     - qwen-turbo: 通义千问 Turbo（速度最快，成本最低）
LLM_RERANKER_MODEL=qwen-plus

# LLM Reranker 的批次大小
# 
# 【作用】: 每次批量处理多少个检索结果
# 【影响】:
#     - 调大：减少 API 调用次数，但单次调用时间更长
#     - 调小：单次调用更快，但 API 调用次数更多
# 【推荐值】: 10（默认）
LLM_RERANKER_BATCH_SIZE=10

# -----------------------------------------------------------------------------
# 服务配置
# -----------------------------------------------------------------------------

# 服务端口
SERVICE_PORT=8002

# 日志级别
# 【可选值】: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 是否启用调试模式
# 【注意】: 生产环境务必设为 False
DEBUG=False
